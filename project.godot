; Godot project for mod resource pack (localization / assets).
config_version=5

[application]

config/name="AnalyticsTelemetry"
config/features=PackedStringArray("4.5", "C#", "Mobile")
config/icon="res://AnalyticsTelemetry/mod_image.png"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/initial_position_type=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="AnalyticsTelemetry"

[rendering]

renderer/rendering_method="mobile"
environment/defaults/default_clear_color=Color(0.0923724, 0.122398, 0.116929, 1)
